{
  "name": "@everything-dev/auth-plugin",
  "version": "1.0.0",
  "description": "Authentication plugin using Better Auth with NEAR Protocol, passkeys, and more",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@libsql/client": "^0.15.7",
    "@orpc/contract": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "better-auth": "^1.6.9",
    "better-near-auth": "catalog:",
    "drizzle-orm": "^0.44.0",
    "every-plugin": "workspace:*"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@module-federation/node": "catalog:",
    "@proj-airi/unplugin-drizzle-orm-migrations": "^0.1.4",
    "@rspack/cli": "^1.6.8",
    "@rspack/core": "^1.6.8",
    "@simplewebauthn/server": "^13.3.0",
    "@types/node": "catalog:",
    "dotenv": "^17.2.3",
    "everything-dev": "workspace:*",
    "drizzle-kit": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "catalog:",
    "zephyr-rspack-plugin": "^1.0.1"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json && tsc -p tsconfig.auth-types.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "bun run build:types && rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  }
}
