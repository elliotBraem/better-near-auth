{
  "extends": "bos://dev.everything.near/everything.dev",
  "account": "auth.everything.near",
  "domain": "everything.dev",
  "title": "Better NEAR Auth",
  "description": "Authentication example app showcasing better-near-auth with NEAR Sign-In, passkeys, GitHub OAuth, organizations, and API keys",
  "testnet": "dev.allthethings.testnet",
  "staging": {
    "domain": "staging.dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "app": {
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    },
    "auth": {
      "name": "everything-dev_auth-plugin",
      "development": "local:plugins/auth",
      "production": "https://elliot-braem-4615-everything-dev-auth-plugin-bett-544a63d21-ze.zephyrcloud.app",
      "integrity": "sha384-hdiTtgW15RyAVkpNdgNxQxKP3xOkMs2jJ27O53l1zEi++nghcPFn8QZQb9avuLMe",
      "variables": {
        "socialProviders": {
          "github": {
            "clientId": ""
          }
        },
        "passkey": {
          "rpID": "everything.dev",
          "rpName": "Better NEAR Auth"
        },
        "siwn": {
          "recipients": {
            "mainnet": "auth.everything.near",
            "testnet": "dev.allthethings.testnet"
          },
          "relayer": {
            "accountId": ""
          }
        }
      },
      "secrets": [
        "AUTH_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "GITHUB_CLIENT_SECRET",
        "FASTNEAR_API_KEY",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_PHONE_NUMBER",
        "NEAR_RELAYER_PRIVATE_KEY",
        "NEAR_SUB_ACCOUNT_PARENT_KEY_MAINNET",
        "NEAR_SUB_ACCOUNT_PARENT_KEY_TESTNET"
      ],
      "shared": {
        "better-auth": {
          "version": "1.6.9",
          "requiredVersion": "^1.6.9",
          "singleton": true,
          "strictVersion": false,
          "shareScope": "default"
        },
        "better-near-auth": {
          "version": "1.6.1",
          "requiredVersion": "^1.5.0",
          "singleton": true,
          "strictVersion": false,
          "shareScope": "default"
        },
        "@better-auth/api-key": {
          "version": "1.6.9",
          "requiredVersion": "^1.6.9",
          "singleton": true,
          "strictVersion": false,
          "shareScope": "default"
        },
        "@better-auth/passkey": {
          "version": "1.6.9",
          "requiredVersion": "^1.6.9",
          "singleton": true,
          "strictVersion": false,
          "shareScope": "default"
        }
      }
    }
  }
}
