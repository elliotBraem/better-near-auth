{
  "extends": "bos://dev.everything.near/everything.dev",
  "account": "auth.everything.near",
  "domain": "everything.dev",
  "testnet": "dev.allthethings.testnet",
  "staging": {
    "domain": "staging.dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "app": {
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    },
    "auth": {
      "name": "everything-dev_auth-plugin",
      "development": "local:plugins/auth",
      "production": "https://elliot-braem-3605-everything-dev-auth-plugin-bett-f19f96ec0-ze.zephyrcloud.app",
      "integrity": "sha384-0+6PBccgYZwLDVxJJ3LDeA0EledPagot9TwxGvq59+qoJaBVc8qHJcxPTJNiHI6X",
      "secrets": [
        "AUTH_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "CORS_ORIGIN",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "PASSKEY_RP_ID",
        "PASSKEY_RP_NAME",
        "PASSKEY_ORIGIN",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_PHONE_NUMBER"
      ]
    }
  },
  "shared": {
    "ui": {
      "effect": {
        "version": "3.21.0",
        "requiredVersion": "^3.21.0",
        "singleton": true,
        "strictVersion": false,
