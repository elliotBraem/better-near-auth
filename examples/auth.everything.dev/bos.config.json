{
  "extends": "bos://dev.everything.near/everything.dev",
  "account": "auth.everything.near",
  "domain": "everything.dev",
  "title": "Better NEAR Auth",
  "description": "Authentication example app showcasing better-near-auth with NEAR Sign-In, passkeys, GitHub OAuth, organizations, and API keys",
  "testnet": "dev.allthethings.testnet",
  "staging": {
    "domain": "staging.dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "app": {
    "host": {
      "development": "local:host",
      "production": "https://elliot-braem-4578-host-everything-dev-nearbuilder-195763a9c-ze.zephyrcloud.app",
      "secrets": [
        "CORS_ORIGIN",
        "TENANT_WHITELIST",
        "ALLOW_OVERRIDE",
        "ALLOW_UNTRUSTED_SSR",
        "CSP_STRICT"
      ],
      "integrity": "sha384-tEguGZihnWOCjrRHrtjycqEQEkNATlaT1FA9yy0NA9IThWMn52dtBZFKppKss5sP"
    },
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    },
    "auth": {
      "name": "everything-dev_auth-plugin",
      "development": "local:plugins/auth",
      "production": "https://elliot-braem-4250-everything-dev-auth-plugin-bett-01cc31550-ze.zephyrcloud.app",
      "integrity": "sha384-HGCj8X8OaADQo1cBP6gyaTEdaGpEqO7EWWlpdp/3Xx4LyM/uVHmLfXTTgdl3NZ9S",
      "variables": {
        "baseUrl": "https://auth.everything.near",
        "trustedOrigins": [
          "https://everything.dev",
          "https://*.everything.dev"
        ],
        "socialProviders": {
          "github": {
            "clientId": ""
          }
        },
        "passkey": {
          "rpID": "everything.dev",
          "rpName": "Better NEAR Auth"
        },
        "siwn": {
          "recipients": {
            "mainnet": "auth.everything.near",
            "testnet": "dev.allthethings.testnet"
          },
          "relayer": {
            "accountId": ""
          }
        }
      },
      "secrets": [
        "AUTH_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "GITHUB_CLIENT_SECRET",
        "FASTNEAR_API_KEY",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_PHONE_NUMBER",
        "NEAR_RELAYER_PRIVATE_KEY",
        "NEAR_SUB_ACCOUNT_PARENT_KEY_MAINNET",
        "NEAR_SUB_ACCOUNT_PARENT_KEY_TESTNET"
      ]
    }
  },
  "plugins": {}
}
