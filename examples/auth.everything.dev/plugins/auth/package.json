{
  "name": "@everything-dev/auth-plugin",
  "version": "1.2.3",
  "description": "Authentication plugin using Better Auth with NEAR Protocol, passkeys, and more",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "better-auth": "1.6.9",
    "better-near-auth": "^1.6.3",
    "drizzle-orm": "^0.45.1",
    "every-plugin": "catalog:",
    "pg": "^8.12.0",
    "@electric-sql/pglite": "^0.4.5"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@module-federation/node": "catalog:",
    "@orpc/contract": "1.13.14",
    "@orpc/server": "1.13.14",
    "@proj-airi/unplugin-drizzle-orm-migrations": "^0.1.4",
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "@simplewebauthn/server": "^13.3.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.6",
    "dotenv": "^17.2.3",
    "everything-dev": "catalog:",
    "drizzle-kit": "^0.31.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17",
    "zephyr-rspack-plugin": "^1.1.0"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "bun run build:types && rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  }
}
